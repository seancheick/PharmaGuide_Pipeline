        "standard_name": "Silicon Dioxide (E551)",
        "severity_level": "low",
        "match_method": "alias_via_std",
        "matched_alias": "silicon dioxide",
        "notes": "Amorphous silicon dioxide is the most common anti-caking agent in supplement manufacturing. FDA GRAS at ≤2%. EFSA 2018 data gap request was precautionary — no finding of harm. Low severity — tracked purely as non-nutritive excipient quality signal.",
        "mechanism_of_harm": "Amorphous silicon dioxide (SiO2) used as anti-caking agent in tablets/capsules at <2% w/w. FDA GRAS (21 CFR 172.480, max 2% of food weight). EFSA 2018 re-evaluation could not confirm safety due to insufficient nanoparticle characterization data — this was a data gap, not a finding of harm. Amorphous SiO2 is poorly absorbed from the GI tract. Nanoparticle concerns are based on in vitro studies at concentrations far exceeding dietary exposure.",
        "common_uses": [
          "flow agent",
          "anti-caking",
          "tablet glidant"
        ],
        "population_warnings": [
          "No specific population concerns at anti-caking agent levels (<2% w/w)"
        ],
        "is_harmful": true,
