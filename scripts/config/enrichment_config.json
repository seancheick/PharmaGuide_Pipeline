{
  "_comments": {
    "USAGE": "HOW TO RUN THE DSLD ENRICHMENT SCRIPT",
    "method_1_config_based": {
      "description": "Use this config file for paths and settings",
      "command": "python enrich_supplements_v3.py --config config/enrichment_config.json",
      "note": "Reads input/output paths and database paths from this config file"
    },
    "method_2_command_line": {
      "description": "Override config with command line arguments",
      "examples": [
        "python enrich_supplements_v3.py --input-dir /path/to/cleaned --output-dir /path/to/output",
        "python enrich_supplements_v3.py --input-dir output_Lozenges/cleaned --output-dir output_Lozenges_enriched --batch-size 100",
        "python enrich_supplements_v3.py --dry-run"
      ]
    },
    "workflow": "1. CLEANING -> 2. ENRICHMENT (this phase) -> 3. SCORING"
  },
  "enrichment_info": {
    "version": "3.1.0",
    "description": "Enrichment configuration for v3 scoring pipeline compatibility",
    "updated": "2026-02-13",
    "author": "PharmaGuide Team",
    "pipeline_stage": "enrichment"
  },
  "paths": {
    "input_directory": "output_Lozenges/cleaned",
    "_input_help": "Directory containing cleaned DSLD JSON files (relative to scripts/)",
    "output_directory": "output_Lozenges_enriched",
    "_output_help": "Output root; script writes enriched data under output_structure.enriched_folder",
    "reference_data": "data",
    "input_file_pattern": "*.json"
  },
  "database_paths": {
    "absorption_enhancers": "data/absorption_enhancers.json",
    "allergens": "data/allergens.json",
    "backed_clinical_studies": "data/backed_clinical_studies.json",
    "banned_recalled_ingredients": "data/banned_recalled_ingredients.json",
    "banned_match_allowlist": "data/banned_match_allowlist.json",
    "botanical_ingredients": "data/botanical_ingredients.json",
    "cert_claim_rules": "data/cert_claim_rules.json",
    "clinical_risk_taxonomy": "data/clinical_risk_taxonomy.json",
    "clinically_relevant_strains": "data/clinically_relevant_strains.json",
    "color_indicators": "data/color_indicators.json",
    "enhanced_delivery": "data/enhanced_delivery.json",
    "harmful_additives": "data/harmful_additives.json",
    "ingredient_quality_map": "data/ingredient_quality_map.json",
    "ingredient_interaction_rules": "data/ingredient_interaction_rules.json",
    "ingredient_weights": "data/ingredient_weights.json",
    "manufacturer_violations": "data/manufacturer_violations.json",
    "other_ingredients": "data/other_ingredients.json",
    "percentile_categories": "data/percentile_categories.json",
    "proprietary_blends": "data/proprietary_blends.json",
    "rda_optimal_uls": "data/rda_optimal_uls.json",
    "rda_therapeutic_dosing": "data/rda_therapeutic_dosing.json",
    "standardized_botanicals": "data/standardized_botanicals.json",
    "synergy_cluster": "data/synergy_cluster.json",
    "top_manufacturers_data": "data/top_manufacturers_data.json",
    "unit_conversions": "data/unit_conversions.json",
    "user_goals_to_clusters": "data/user_goals_to_clusters.json"
  },
  "processing_config": {
    "batch_size": 100,
    "max_workers": 4,
    "collect_rda_ul_data": true,
    "_collect_rda_ul_data_help": "MUST be true: the scorer's B7 dose-safety penalty (OVER-150%-UL teratogenicity check, incl. D4.3 canonical-sum aggregation) reads from enriched.rda_ul_data.safety_flags. When false, B7 silently returns 0 for every product \u2014 medical-safety gap. The Flutter detail blob also surfaces rda_ul_data for the aggregated UL warning card.",
    "enable_fuzzy_matching": true,
    "fuzzy_threshold": 85,
    "enable_logging": true,
    "log_level": "INFO"
  },
  "validation": {
    "strict_db_validation": false,
    "_strict_db_validation_help": "If true, fail-fast on DB key violations (recommended in CI)"
  },
  "output_structure": {
    "enriched_folder": "enriched",
    "reports_folder": "reports",
    "batch_prefix": "enriched_",
    "report_prefix": "enrichment_summary",
    "file_extension": ".json"
  },
  "options": {
    "generate_reports": true
  },
  "ui": {
    "show_progress_bar": true
  }
}
