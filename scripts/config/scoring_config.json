{
  "_documentation": {
    "version": "3.0.1",
    "description": "PharmaGuide scoring configuration aligned to v3.0 arithmetic-only scoring",
    "total_points": "80 calculated server-side (A+B+C+D), 20 fit score computed on device",
    "last_updated": "2026-02-13",
    "author": "PharmaGuide Team",
    "changelog": [
      "3.0.1: Normalized config to v3.0 section caps and penalty-sign convention; scoring gate kept open for rollout",
      "3.0.0: Arithmetic-only scorer; matching and NLP moved to enrichment"
    ]
  },
  "_important_rules": {
    "config_driven": "Point values and gates live here; scorer reads enriched fields and performs arithmetic only",
    "penalty_sign_convention": "Penalties are positive magnitudes and are subtracted in formulas",
    "single_verdict": "Verdict precedence is deterministic; first matching rule wins"
  },
  "feature_gates": {
    "_description": "Scoring rollout controls",
    "require_full_mapping": true,
    "_require_full_mapping_note": "ENFORCED: any unmapped active returns NOT_SCORED; keep blend/header classification clean.",
    "probiotic_extended_scoring": false,
    "_probiotic_extended_scoring_note": "When true, use extended probiotic bonus module (max +10)",
    "allow_non_probiotic_probiotic_bonus_with_strict_gate": true,
    "_allow_non_probiotic_probiotic_bonus_with_strict_gate_note": "When true, non-probiotic products can receive probiotic bonus only if strict evidence gates pass.",
    "shadow_mode": true
  },
  "_usage": {
    "run_scoring": "python score_supplements.py",
    "run_pipeline": "python run_pipeline.py --stages clean,enrich,score",
    "custom_input": "python score_supplements.py --input-dir path/to/enriched --output-dir path/to/scored",
    "dry_run": "python score_supplements.py --dry-run"
  },
  "paths": {
    "input_directory": "output_Lozenges_enriched/enriched",
    "_input_help": "Directory containing enriched JSON files (relative to scripts/)",
    "output_directory": "output_Lozenges_scored",
    "_output_help": "Directory where scored output will be written",
    "enriched_folder": "scored",
    "reports_folder": "reports"
  },
  "section_maximums": {
    "_comment": "v3.0 exact section caps. A+B+C+D = 80.",
    "A_ingredient_quality": 25,
    "B_safety_purity": 35,
    "C_evidence_research": 15,
    "D_brand_trust": 5,
    "E_user_profile": 20,
    "_E_note": "Section E is client-side only and is not computed by this script",
    "total_calculated": 80,
    "_total_note": "Quality score stored server-side. Combined score is Quality(80) + Fit(20) = 100 display",
    "total_with_E": 100
  },
  "section_A_ingredient_quality": {
    "_max": 25,
    "A1_bioavailability_form": {
      "max": 13,
      "range_score_field": "0-18",
      "multivitamin_smoothing_factor": 0.7,
      "multivitamin_floor": 9
    },
    "A2_premium_forms": {
      "max": 3,
      "threshold_score": 14,
      "points_per_additional_premium_form": 0.5,
      "skip_first_premium_form": true
    },
    "A3_delivery_system": {
      "max": 3,
      "tier_points": {
        "1": 3,
        "2": 2,
        "3": 1
      },
      "_note": "Scoring reads enriched delivery_tier; no text matching at scoring time"
    },
    "A4_absorption_enhancer": {
      "max": 3,
      "points_if_paired": 3,
      "_note": "Scoring reads enriched absorption_enhancer_paired boolean"
    },
    "A5_formulation_excellence": {
      "max": 3,
      "organic": 1,
      "standardized_botanical": 1,
      "synergy_cluster": 1
    },
    "probiotic_bonus": {
      "default_max": 3,
      "extended_max": 10,
      "extended_gate": "probiotic_extended_scoring",
      "non_probiotic_strict_gate": {
        "require_viable_cfu": true,
        "min_total_billion_count": 1.0,
        "require_strain_level_identity": true,
        "min_clinical_strain_count": 1,
        "min_strain_id_count": 1,
        "require_cfu_guarantee": true,
        "accepted_guarantee_types": [
          "at_expiration"
        ],
        "require_explicit_intent": true,
        "explicit_intent_terms": [
          "probiotic",
          "probiotics",
          "live cultures",
          "cfu",
          "gut flora",
          "microbiome"
        ]
      }
    }
  },
  "section_B_safety_purity": {
    "_max": 35,
    "base_score": 35,
    "_formula": "B = clamp(0, 35, 35 + bonuses - penalties)",
    "B0_immediate_fail": {
      "moderate_penalty": 10,
      "allowed_match_types_for_hard_fail": [
        "exact",
        "alias"
      ],
      "review_only_match_types": [
        "token_bounded"
      ]
    },
    "B1_harmful_additives": {
      "cap": 5,
      "risk_points": {
        "high": 2.0,
        "moderate": 1.0,
        "low": 0.5,
        "none": 0.0
      }
    },
    "B2_allergen_presence": {
      "cap": 2,
      "severity_points": {
        "high": 2.0,
        "moderate": 1.5,
        "low": 1.0
      }
    },
    "B3_claim_compliance": {
      "cap": 4,
      "allergen_free": 2,
      "gluten_free": 1,
      "vegan_vegetarian": 1
    },
    "B4_quality_certifications": {
      "cap_total": 21,
      "B4a_named_programs": {
        "points_per_program": 5,
        "cap": 15
      },
      "B4b_gmp": {
        "certified": 4,
        "fda_registered": 2
      },
      "B4c_batch_traceability": {
        "coa": 1,
        "batch_lookup": 1
      }
    },
    "B5_proprietary_blends": {
      "cap": 15,
      "disclosure_base": {
        "full": 0,
        "partial": 3,
        "none": 6
      }
    },
    "B6_marketing_penalty": {
      "penalty": 5
    }
  },
  "section_C_evidence_research": {
    "_max": 15,
    "cap_per_ingredient": 5,
    "cap_total": 15,
    "evidence_level_multipliers": {
      "product-human": 1.0,
      "branded-rct": 0.8,
      "ingredient-human": 0.65,
      "strain-clinical": 0.6,
      "preclinical": 0.3
    },
    "study_type_base_points": {
      "systematic_review_meta": 6,
      "rct_multiple": 5,
      "rct_single": 4,
      "clinical_strain": 4,
      "observational": 2,
      "animal_study": 2,
      "in_vitro": 1
    },
    "sub_clinical_dose_guard_multiplier": 0.25,
    "_canonical_key": "entry.standard_name"
  },
  "section_D_brand_trust": {
    "_max": 5,
    "D1_manufacturer_reputation": 2,
    "D2_disclosure_quality": 1,
    "D3_physician_formulated": 0.5,
    "D4_high_standard_region": 0.5,
    "D5_sustainability": 0.5,
    "D3_D4_D5_combined_cap": 1.5
  },
  "manufacturer_violations": {
    "cap_total": -25,
    "stored_sign": "negative",
    "_note": "Read total_deduction_applied and add directly to quality_raw"
  },
  "verdict_rules": {
    "_precedence": [
      "BLOCKED",
      "UNSAFE",
      "NOT_SCORED",
      "CAUTION",
      "POOR",
      "SAFE"
    ],
    "poor_threshold_quality_score": 32
  },
  "display_format": {
    "primary": "{score}/80",
    "equivalent": "{score_100}/100"
  },
  "grade_scale": {
    "_based_on_100_equivalent": true,
    "Exceptional": {
      "min": 90
    },
    "Excellent": {
      "min": 80
    },
    "Good": {
      "min": 70
    },
    "Fair": {
      "min": 60
    },
    "Below Avg": {
      "min": 50
    },
    "Low": {
      "min": 32
    },
    "Very Poor": {
      "min": 0
    }
  },
  "score_floors_and_ceilings": {
    "total_floor": 0,
    "total_ceiling": 80,
    "probiotic_bonus_applies_before_ceiling": true
  },
  "legacy_compat": {
    "section_b": {
      "B4_proprietary_blends": {
        "cap_total": -15,
        "base_penalties": {
          "none": 6,
          "partial": 3,
          "full": 0
        }
      }
    }
  },
  "processing": {
    "batch_size": 100,
    "show_progress_bar": true
  }
}
