  "nutritionalInfo": {},
  "statements": [
    {
      "type": "General Statements: All Other Content",
      "notes": "The B-12 content is derived by natural fermentation.\n"
    },
    {
      "type": "Suggested/Recommended/Usage/Directions",
      "notes": "SUGGESTED USAGE: As a dietary supplement, take one lozenge daily. Chew lozenge or hold in mouth until dissolved. Consider taking this product in combination with NOW(R) B-Complex, Folic Acid, B-6 and TMG."
    },
    {
      "type": "General Statements: All Other Content",
      "notes": "Vitamin B-12 (Cyanocobalamin) is a water soluble vitamin necessary for the maintenance of a healthy nervous system and for the metabolic utilization of fats and proteins. Vitamin B-12 is also essential for the synthesis of DNA during cell division and therefore is especially important for rapidly multiplying cells, such as blood cells. In addition, adequate intake of Vitamin B-12, along with Folic Acid and Vitamin B-6, encourages healthy serum homocysteine levels, thereby supporting cardiovascular health. Because Vitamin B-12 is found predominantly in animal products, strict vegetarians are at risk of developing Vitamin B-12 deficiency and may benefit from supplementation.*"
    },
    {
      "type": "Formulation re: Vegetarian/Vegan",
      "notes": "NOW(R) Vitamin B-12 is vegetarian/ vegan (non-animal derived)."
    },
