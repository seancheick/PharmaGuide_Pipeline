{
  "_metadata": {
    "description": "Controlled vocabulary for ingredient FORM KEYWORDS extracted from raw label text. Single source of truth for the cleaner (extracts forms from ingredient names), the scorer (gates premium-form bonuses), and the enricher (matches probiotic delivery / postbiotic patterns). Replaces 3-5 hardcoded duplicate keyword lists previously scattered across enhanced_normalizer.py, score_supplements.py, enrich_supplements_v3.py, constants.py, and ingredient_quality_map.json aliases.",
    "schema_version": "1.0.0",
    "total_entries": 17,
    "last_updated": "2026-05-05",
    "total_categories": 17,
    "status": "ACTIVE — v1.5.0 form vocabulary refactor",
    "purpose": "Extraction patterns + canonical names for every form keyword the pipeline recognizes. Each consumer loads this once at import time, compiles regexes, and reads canonical names. Drift across consumers is no longer possible — they all read this file.",
    "consumed_by": [
      "scripts/enhanced_normalizer.py (cleaner — extracts forms[] from ingredient names)",
      "scripts/score_supplements.py (scorer — gates A2 omega-3 premium-form bonus)",
      "scripts/enrich_supplements_v3.py (enricher — detects probiotic delivery + postbiotic)",
      "scripts/form_vocab.py (loader — compiles regex tables from this file)"
    ],
    "field_contract": {
      "categories": "Object keyed by category id. Each category has: description, scoring_relevance, forms.",
      "forms": "List of form entries (ordered — earlier entries take precedence when patterns overlap). Each entry has: canonical (the canonical name emitted), patterns (regex strings, IGNORECASE).",
      "canonical": "The single canonical string this form is normalized to. Cleaner emits this into forms[].name; scorer haystack regex matches against this; enricher matches against this for keyword decisions.",
      "patterns": "List of regex patterns (raw strings, no anchors). Compiled with re.IGNORECASE. Order within the patterns list is irrelevant — the canonical name is what's emitted on any match.",
      "scoring_relevance": "Free-text note explaining what this category gates. Documentation only — does not affect runtime."
    },
    "ordering_rule": "Within a category, more specific forms must come BEFORE less specific ones so the cleaner's first-match wins. e.g. 're-esterified triglyceride' must precede 'triglyceride'."
  },
  "categories": {
    "omega3_molecular_forms": {
      "description": "Molecular forms of EPA/DHA. Drives the scorer's A2 premium-delivery bonus (score_supplements._PREMIUM_OMEGA3_FORM_PATTERN). rTG > natural TG > TG > phospholipid > monoglyceride > FFA > ethyl ester (cheapest).",
      "scoring_relevance": "premium_form_bonus_a2",
      "forms": [
        {
          "canonical": "re-esterified triglyceride",
          "patterns": ["\\brtg\\b", "re-?esterified\\s+triglyceride"]
        },
        {
          "canonical": "natural triglyceride",
          "patterns": ["\\bnatural\\s+triglyceride\\b"]
        },
        {
          "canonical": "triglyceride",
          "patterns": ["\\btriglyceride\\b"]
        },
        {
          "canonical": "krill phospholipid",
          "patterns": ["\\bkrill\\s+phospholipid\\b"]
        },
        {
          "canonical": "phospholipid",
          "patterns": ["\\bphospholipid\\b"]
        },
        {
          "canonical": "monoglyceride",
          "patterns": ["\\bmonoglyceride\\b"]
        },
        {
