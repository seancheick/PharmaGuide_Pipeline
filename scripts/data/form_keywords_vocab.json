          "patterns": ["\\bfree\\s+fatty\\s+acid\\b", "\\bffa\\b"]
        },
        {
          "canonical": "ethyl ester",
          "patterns": ["\\bethyl\\s+ester\\b", "\\bee\\b"]
        }
      ]
    },
