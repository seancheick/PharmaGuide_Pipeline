{
  "_metadata": {
    "description": "Ingredient classification rules for active/inactive categorization",
    "purpose": "ingredient_classification",
    "schema_version": "5.0.0",
    "last_updated": "2026-03-09",
    "version": "1.0.0",
    "total_entries": 20
  },
  "settings": {
    "enable_case_insensitive": true,
    "tier_b_normalization": {
      "unicode": "NFC",
      "trim": true,
      "collapse_whitespace": true,
      "notes": "Tier B only. No punctuation stripping, no stemming, no qualifier removal."
    }
  },
  "skip_exact": [
    "DELETE",
    "Less than 2% of:",
    "Less than 2% of",
    "Contains <2% of:",
    "Contains <2% of",
    "Contains < 2% of:",
    "Contains < 2% of",
    "Contains 2% or less of the following",
    "Contains less than 2% of",
    "Total EPA & DHA",
    "Total EPA and DHA",
    "Total Omega Oil",
    "Total Omega Fatty Acids",
    "Essential Fatty Acids",
    "Omega 3, 6, 9",
    "Total Probiotic Cultures",
    "Total Phytocannabinoids",
    "Other Ingredients",
    "Inactive Ingredients",
    "Active Ingredients",
    "Total Omega",
    "Total Omega-3-5-6-7-8-9-11",
    "Palmitic Acid, Stearic Acid",
    "Safflower/Sunflower Oil concentrate",
    "Other Omega-3's",
    "High Choline Lecithin"
  ],
  "classifications": {
    "Total EPA & DHA": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score components (EPA/DHA) instead."
    },
    "Total Probiotic Cultures": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score specific strains/CFUs instead."
    },
    "Total Phytocannabinoids": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score individual cannabinoids instead."
    },
    "Less than 2% of:": {
      "hierarchy": "label_header",
      "scoring_rule": "skip_all",
      "note": "Drop header; extract forms[] as children when present."
    },
    "Total Omega": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score specific omega subclasses instead."
    },
    "Total Omega-3-5-6-7-8-9-11": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score specific nested omega subclasses instead."
    },
    "Palmitic Acid, Stearic Acid": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score the explicit child fatty acids instead of the combined label wrapper."
    },
    "Safflower/Sunflower Oil concentrate": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score explicit child fatty acids instead of the blended source-oil wrapper."
    },
    "Other Omega-3's": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Summary remainder row; score the explicit omega-3 components instead."
    },
    "High Choline Lecithin": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Wrapper/source row for phosphatidylcholine-rich lecithin; score explicit phosphatidylcholine child/paired row instead."
    }
  }
}
