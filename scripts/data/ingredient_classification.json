    "version": "1.0.0",
    "total_entries": 20
  },
  "settings": {
    "enable_case_insensitive": true,
    "tier_b_normalization": {
      "unicode": "NFC",
      "trim": true,
      "collapse_whitespace": true,
      "notes": "Tier B only. No punctuation stripping, no stemming, no qualifier removal."
    }
  },
  "skip_exact": [
    "DELETE",
    "Less than 2% of:",
    "Less than 2% of",
    "Contains <2% of:",
    "Contains <2% of",
    "Contains < 2% of:",
    "Contains < 2% of",
    "Contains 2% or less of the following",
    "Contains less than 2% of",
    "Total EPA & DHA",
    "Total EPA and DHA",
    "Total Omega Oil",
    "Total Omega Fatty Acids",
    "Essential Fatty Acids",
    "Omega 3, 6, 9",
    "Total Probiotic Cultures",
    "Total Phytocannabinoids",
    "Other Ingredients",
    "Inactive Ingredients",
    "Active Ingredients"
  ],
  "classifications": {
    "Total EPA & DHA": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score components (EPA/DHA) instead."
    },
    "Total Probiotic Cultures": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score specific strains/CFUs instead."
    },
    "Total Phytocannabinoids": {
      "hierarchy": "summary",
      "scoring_rule": "skip_all",
      "note": "Score individual cannabinoids instead."
    },
    "Less than 2% of:": {
      "hierarchy": "label_header",
      "scoring_rule": "skip_all",
      "note": "Drop header; extract forms[] as children when present."
    }
  }
