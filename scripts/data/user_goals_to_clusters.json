{
  "_metadata": {
    "description": "Mapping of user health goals to ingredient synergy clusters for personalized recommendations",
    "purpose": "goal_mapping",
    "schema_version": "5.2.0",
    "last_updated": "2026-04-02",
    "total_entries": 18,
    "schema_notes": {
      "cluster_weights": "Float 0.0-1.0 per cluster. 1.0 = core to goal, 0.7-0.9 = strongly relevant, 0.4-0.6 = moderately relevant. Used to compute goal_fit_score per supplement.",
      "core_clusters": "Cluster IDs that must be present for goal satisfaction. A product missing all core clusters is disqualified from this goal regardless of other matches.",
      "anti_clusters": "Cluster IDs that are counterproductive for this goal. A matched anti-cluster contributes 0.0 to goal_fit_score (zero-out, not penalty).",
      "cluster_limits": "Max cluster hits counted per cluster when computing goal_fit_score. Prevents single-category over-stacking (e.g., 5 sleep ingredients all from sleep_stack still counts as 1 hit).",
      "confidence_threshold": "Minimum normalized cluster coverage (0.0-1.0) for a product to qualify as relevant to this goal. Higher = stricter matching.",
      "goal_priority": "Onboarding sort order: high surfaces first. Values: high, medium, low.",
      "goal_category": "UI grouping key for the Flutter app. Values: mental, metabolic, cardiovascular, fitness, hormonal, immune, longevity, aesthetic, sensory, reproductive.",
      "conflicting_goals": "Goal IDs that are fundamentally at odds from a UX intent perspective. App warns user when both are selected simultaneously.",
      "synergy_goals": "Goal IDs that naturally complement this goal. App may suggest bundling these together."
    }
  },
