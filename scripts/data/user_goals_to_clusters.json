{
  "_metadata": {
    "description": "User goal to product-cluster matching rules (pipeline-owned matching contract)",
    "purpose": "goal_matching",
    "schema_version": "6.0.0",
    "last_updated": "2026-04-23",
    "total_entries": 18,
    "schema_notes": {
      "cluster_weights": "Float 0.0-1.0 per cluster. 1.0 = core to goal, 0.7-0.9 = strongly relevant, 0.4-0.6 = moderately relevant. Used to compute matched_weight / max_weight per supplement.",
      "required_clusters": "Cluster IDs that must be present for goal to qualify. If non-empty and none are present, the goal is not matched regardless of weighted score.",
      "blocked_by_clusters": "Cluster IDs that disqualify a product from this goal. If any blocked cluster is present, the goal is not matched regardless of weighted score.",
      "min_match_score": "Minimum normalized score (matched_weight / max_weight) required for the goal to be included in goal_matches. Range (0.0, 1.0]."
    },
    "matching_algorithm": "score = sum(cluster_weights[c] for c in product_clusters_dedup if c in cluster_weights) / sum(cluster_weights.values()); goal matches when score >= min_match_score AND no blocked cluster present AND (required_clusters empty OR at least one required present).",
    "canonical_id_source": "Flutter app authoritative goal IDs (18 entries)."
  },
