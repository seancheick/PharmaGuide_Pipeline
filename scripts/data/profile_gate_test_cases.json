  "_metadata": {
    "description": "Shared evaluator fixture for v6.0 profile_gate. Python (scripts/profile_gate_evaluator.py) and Dart (Flutter alert-rendering layer) MUST both produce the same fires/severity output for every case below. Drift between the two implementations is the failure this fixture catches.",
    "purpose": "profile_gate_evaluator_cross_runtime_fixture",
    "schema_version": "1.0.0",
    "total_entries": 18,
    "evaluator_contract_version": "6.0",
    "last_updated": "2026-05-13",
    "case_count": 18,
    "see_also": [
      "scripts/INTERACTION_RULE_SCHEMA_V6_ADR.md",
      "scripts/profile_gate_evaluator.py"
    ]
  },
  "test_cases": [
    {
      "name": "condition_gate_diabetes_match",
      "description": "Diabetic user matches condition gate",
      "gate": {
        "gate_type": "condition",
        "requires": {"conditions_any": ["diabetes"], "drug_classes_any": [], "profile_flags_any": []},
        "excludes": {"conditions_any": [], "drug_classes_any": [], "profile_flags_any": [], "product_forms_any": [], "nutrient_forms_any": []},
        "dose": null
      },
      "user_profile": {"conditions": ["diabetes"], "drug_classes": [], "profile_flags": []},
      "product_context": {"product_form": null, "nutrient_form": null, "dose_per_day": null, "dose_unit": null},
      "base_severity": "caution",
      "expected": {"fires": true, "severity": "caution"}
    },
