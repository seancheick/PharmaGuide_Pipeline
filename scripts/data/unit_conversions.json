  "form_detection_patterns": {
    "_description": "Regex patterns to detect vitamin forms from ingredient names",
    "vitamin_e": {
      "natural_patterns": [
        "\\bd-alpha",
        "\\bRRR-alpha",
        "\\bnatural\\s+(vitamin\\s+)?E\\b",
        "\\bd-alpha-tocopherol",
        "\\bd-alpha-tocopheryl"
      ],
      "synthetic_patterns": [
        "\\bdl-alpha",
        "\\ball-rac",
        "\\bsynthetic\\s+(vitamin\\s+)?E\\b",
        "\\bdl-alpha-tocopherol",
        "\\bdl-alpha-tocopheryl"
      ],
      "default_if_unknown": "synthetic",
      "notes": "If form cannot be determined, assume synthetic (conservative)"
    },
    "vitamin_a": {
      "retinol_patterns": [
        "\\bretinol\\b",
        "\\bretinyl\\s+palmitate",
        "\\bretinyl\\s+acetate",
        "\\bpreformed\\s+(vitamin\\s+)?A\\b",
        "\\bvitamin\\s+A\\s+(palmitate|acetate)\\b"
      ],
      "beta_carotene_patterns": [
        "\\bbeta[- ]?carotene\\b",
        "\\bprovitamin\\s+A\\b",
        "\\bcarotenoid"
      ],
      "default_if_unknown": "flag_for_review",
      "notes": "Do NOT default - flag for review if form unknown (UL implications)"
    }
  }
