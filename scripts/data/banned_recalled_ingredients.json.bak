    {
      "id": "SPIKE_METHYL7K",
      "standard_name": "7-Methylkratom",
      "aliases": [
        "7-MK",
        "7 methylkratom",
        "7-methyl kratom",
        "methylated kratom extract",
        "enhanced kratom",
        "7-methyl mitragynine",
        "7-methylkratom"
      ],
      "reason": "7-Methylkratom refers to semi-synthetic derivatives of mitragynine (kratom's primary alkaloid) designed to increase potency. The most clinically significant is 7-hydroxymitragynine — a metabolite also created synthetically — which has potency far exceeding natural kratom and full mu-opioid receptor agonist activity. These semi-synthetic opioids carry overdose risk equivalent to pharmaceutical opioids. FDA has issued safety alerts and DEA has initiated scheduling proceedings for these compounds. See also: BANNED_7_HYDROXYMITRAGYNINE.",
