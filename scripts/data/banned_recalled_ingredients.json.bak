    {
      "id": "RC_CARDARINE_ANALOGS",
      "standard_name": "Policy Watchlist: Cardarine Derivatives",
      "aliases": [
        "cardarine derivatives",
        "gw501516 analogs",
        "modified cardarine",
        "pparδ agonists",
        "gw-501516 derivatives"
      ],
      "reason": "This watchlist covers synthetic derivatives of GW501516 (Cardarine) — a PPAR-delta agonist whose parent compound caused rapid multi-tissue carcinogenesis in animal trials. Designer analogs are created to evade detection of GW501516 itself while attempting to retain the metabolic and endurance effects. None have any approved human use, safety data, or dietary ingredient status. FDA considers all such analogs to be adulterants. Products containing Cardarine derivatives should be treated with the same concern as the parent compound.",
      "status": "banned",
