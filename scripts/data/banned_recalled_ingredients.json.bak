    {
      "id": "BANNED_SUNIFIRAM",
      "standard_name": "Sunifiram",
      "aliases": [
        "DM-235",
        "1-benzoyl-4-propanoylpiperazine",
        "sunifiram"
      ],
      "reason": "Sunifiram (DM-235) is a synthetic pyrrolidone compound and ampakine nootropic — structurally related to racetams but more potent. It has never been investigated in human clinical trials and has no established safety profile in humans. No NDI notification has been filed. It is not a dietary ingredient under 21 U.S.C. §321(ff). Products selling it as a supplement are adulterated with an untested research chemical. Preclinical data suggests high potency AMPA receptor modulation, with unknown effects on seizure threshold and neurological development at supplement doses.",
      "status": "banned",
      "class_tags": [
        "nootropic_banned",
        "nootropic"
      ],
      "match_rules": {
        "exclusions": [],
        "case_sensitive": false,
