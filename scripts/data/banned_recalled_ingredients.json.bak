    {
      "id": "BANNED_YELLOW_OLEANDER_RECENT",
      "standard_name": "Yellow Oleander (Recent Recalls 2025)",
      "aliases": [
        "yellow oleander",
        "cascabela thevetia",
        "thevetia peruviana",
        "lucky nut",
        "be-still tree",
        "yellow oleander seeds",
        "thevetia neriifolia",
        "yellow oleander (recent recalls 2025)"
      ],
      "reason": "Yellow oleander (Thevetia peruviana) contains cardiac glycosides (thevetin A and B, cerberin) that cause life-threatening cardiotoxicity — bradycardia, heart block, ventricular arrhythmia — at very low doses. It has been substituted into tejocote root supplements (a folk weight-loss ingredient) in multiple documented cases, where the substitution was not disclosed on labels. FDA issued a safety alert in 2021 and multiple 2024–2025 recalls after hospitalizations and deaths were linked to adulterated tejocote products. Any supplement sourced or labeled as tejocote root should be treated with extreme caution.",
      "status": "banned",
      "class_tags": [
        "permanently_banned",
        "botanical_toxic"
      ],
