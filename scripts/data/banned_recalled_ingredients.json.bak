    {
      "id": "BANNED_BVO_2024",
      "standard_name": "Brominated Vegetable Oil",
      "aliases": [
        "BVO",
        "E443",
        "brominated soybean oil",
        "brominated vegetable oil",
        "brominated oil"
      ],
      "reason": "Brominated vegetable oil (BVO) is a food additive formerly used to stabilize citrus-flavored drinks. In July 2024, FDA revoked its authorization for use as a food ingredient, citing animal studies demonstrating accumulation of bromine in the thyroid and fat tissue and potential for thyroid hormone disruption and reproductive toxicity. BVO is now prohibited in US food. Several major beverage companies had already reformulated before the ban. Any supplement or food product still listing BVO as an ingredient is non-compliant following the effective date of FDA's final rule.",
      "status": "banned",
      "class_tags": [
        "permanently_banned",
        "food_additive_emulsifier"
      ],
