    {
      "id": "SPIKE_TADALAFIL",
      "standard_name": "Tadalafil",
      "aliases": [
        "cialis",
        "adcirca",
        "tadalafil citrate",
        "tadalafil"
      ],
      "reason": "Tadalafil (Cialis) is a prescription PDE5 inhibitor for erectile dysfunction, benign prostatic hyperplasia, and pulmonary arterial hypertension. It has a long half-life (~17.5 hours) that makes undeclared dosing especially dangerous — users taking nitrates for heart conditions can experience severe, potentially fatal hypotension. FDA has identified tadalafil as one of the most common pharmaceutical adulterants in sexual enhancement supplements. Products containing undeclared tadalafil are adulterated with a prescription drug.",
