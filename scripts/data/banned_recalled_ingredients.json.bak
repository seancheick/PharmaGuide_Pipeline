      "id": "ADULTERANT_RIMONABANT",
      "standard_name": "Rimonabant",
      "aliases": [
        "acomplia",
        "zimulti",
        "rimonabant hydrochloride",
        "SR141716",
        "rimonabant"
      ],
      "reason": "Rimonabant (Acomplia) was a weight-loss drug that blocked cannabinoid CB1 receptors. It was never FDA-approved — the agency's advisory committee rejected it due to severe psychiatric side effects including depression, anxiety, and suicidal ideation in clinical trials. It was briefly approved in the EU (2006) before being withdrawn in 2008 after post-market safety signals. When found undeclared in supplements, users face psychiatric risks with no informed consent, no psychiatric screening, and no medical supervision.",
      "status": "banned",
      "class_tags": [
        "pharmaceutical_adulterants",
        "drug_weight_loss"
      ],
