    {
      "id": "SYNTH_CUMYL_PICA",
      "standard_name": "CUMYL-PICA",
      "aliases": [
        "SGT-263",
        "cumyl-pica"
      ],
      "reason": "CUMYL-PICA is a synthetic cannabinoid receptor agonist (SCB) — a 'designer drug' engineered to activate CB1 and CB2 receptors with far greater potency than natural THC. Synthetic cannabinoids have caused mass poisoning events, hospitalizations, and deaths globally. They are DEA Schedule I controlled substance analogs. CUMYL-PICA and related SCBs are not dietary ingredients, have no approved human use, and their presence in any product constitutes an adulterated controlled substance. Effects include agitation, tachycardia, seizures, acute kidney injury, and cardiovascular events.",
      "status": "banned",
      "class_tags": [
        "synthetic_cannabinoids",
        "cannabinoid_synthetic"
      ],
