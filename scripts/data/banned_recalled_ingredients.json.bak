    {
      "id": "SPIKE_METHOCARBAMOL",
      "standard_name": "Methocarbamol",
      "aliases": [
        "methocarbamol",
        "robaxin",
        "guaiacol glyceryl ether carbamate",
        "3-(2-methoxyphenoxy)-1,2-propanediol 1-carbamate"
      ],
      "reason": "Methocarbamol is a prescription central muscle relaxant (CNS depressant) used for acute musculoskeletal pain and muscle spasms. When found undeclared in dietary supplements, it creates serious CNS depression risks — dizziness, sedation, and impaired coordination — particularly dangerous for users who drive or operate machinery. Combined with alcohol, benzodiazepines, or opioids, the CNS depression can be life-threatening. FDA considers any supplement containing undeclared methocarbamol to be adulterated with a prescription drug.",
      "status": "banned",
      "class_tags": [
        "illegal_spiking_agents",
