    {
      "id": "RECALLED_JACK3D",
      "standard_name": "Jack3d",
      "aliases": [
        "jack3d",
        "usplabs jack3d",
        "jack3d micro"
      ],
      "reason": "Jack3d (USPlabs) was recalled after the product — which contained DMAA (1,3-dimethylamylamine) as an active ingredient — was linked to two deaths of US military personnel during exercise, as well as multiple hospitalizations from hemorrhagic stroke and heart attack. The US Army banned Jack3d from military installations in 2012. The Department of Defense subsequently launched a comprehensive supplement safety review. FDA issued warning letters and worked with USPlabs to remove DMAA-containing products. This case drove DMAA's formal classification as an unlawful dietary ingredient.",
