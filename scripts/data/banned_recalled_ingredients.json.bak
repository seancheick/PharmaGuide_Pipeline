    {
      "id": "HM_CHROMIUM_HEXAVALENT",
      "standard_name": "Chromium (VI) — Hexavalent Chromium",
      "aliases": [
        "hexavalent chromium",
        "chromium 6",
        "Cr(VI)",
        "chromium(6+)",
        "chromate",
        "chromium 6",
        "CrVI",
        "chromium hexavalent",
        "hexavalent chromium compounds"
      ],
      "reason": "Chromium(VI) is an IARC Group 1 human carcinogen (inhalation — lung and nasal cancers). NTP 2008 TR-546 found clear evidence of oral carcinogenicity in rats (small intestine tumors). EU CLP Category 1A carcinogen AND 1A mutagen. EPA Group A carcinogen. Not a permitted food additive or supplement ingredient in any jurisdiction — it is a contaminant only. Any supplement containing Cr(VI) is adulterated. Mechanism: Cr(VI) crosses cell membranes via sulfate/phosphate anion transporters, undergoes intracellular reductive activation through Cr(V)/Cr(IV) to Cr(III), generating ROS, Cr-DNA adducts, DNA-protein crosslinks, and strand breaks. IMPORTANT: Chromium(III) (picolinate, polynicotinate, etc.) is the beneficial supplemental form — only Cr(VI) compounds are carcinogenic.",
      "status": "high_risk",
      "class_tags": [
        "heavy_metal_limits",
        "heavy_metal"
      ],
