    {
      "id": "BANNED_DYMETHAZINE",
      "standard_name": "Dymethazine",
      "aliases": [
        "dymethazine",
        "dimethazine",
        "dymethazine supplement",
        "d-zine",
        "d zine",
        "methasterone azine"
      ],
      "reason": "Dymethazine (DMZ, 17β-hydroxy-2α,17β-dimethyl-5α-androstan-3-one-azine) is a synthetic anabolic-androgenic steroid prohormone. It converts to two methylated steroidal compounds in the body. Despite being sold as a 'prohormone' supplement, it meets the DEA definition of an anabolic steroid under the Anabolic Steroid Control Act. Risks include severe hepatotoxicity (cholestatic jaundice, peliosis hepatis), cardiovascular effects, endocrine suppression, and virilization. Products containing DMZ have been subject to FDA enforcement and recall actions.",
      "status": "banned",
      "class_tags": [
        "permanently_banned",
        "steroid"
      ],
