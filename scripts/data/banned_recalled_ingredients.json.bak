    {
      "id": "SPIKE_CHLOROPRETADALAFIL",
      "standard_name": "Chloropretadalafil",
      "aliases": [
        "chloro-tadalafil",
        "chloro pretadalafil",
        "chloropre tadalafil",
        "designer tadalafil analog",
        "chloropretadalafil"
      ],
      "reason": "Chloropretadalafil is a synthetic analog of tadalafil designed to evade detection while delivering PDE5 inhibitor activity equivalent to the prescription drug. Its presence in supplements is always undeclared. The same cardiovascular risks apply as with tadalafil — life-threatening hypotension with nitrates — but standard screening may not identify it. FDA considers chloropretadalafil an undeclared pharmaceutical adulterant. No safety or efficacy data exists for this specific analog in humans.",
      "status": "banned",
