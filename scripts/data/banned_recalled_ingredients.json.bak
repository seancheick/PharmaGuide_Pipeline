    {
      "id": "BANNED_14_BUTANEDIOL",
      "standard_name": "1,4-Butanediol",
      "aliases": [
        "1,4-BD",
        "14BD",
        "BDO",
        "butylene glycol",
        "tetramethylene glycol",
        "1,4-butylene glycol",
        "1,4-butanediol"
      ],
      "reason": "1,4-Butanediol (1,4-BD) is an industrial solvent that is rapidly metabolized to GHB (gamma hydroxybutyrate, a Schedule I controlled substance / CNS depressant) by the enzyme alcohol dehydrogenase. It has been found in dietary supplements and 'relaxation drinks.' FDA has issued import alerts and enforcement actions. 1,4-BD causes dose-dependent CNS depression, respiratory depression, and death — with a narrow therapeutic window made worse because conversion speed varies by individual. Multiple fatalities have been reported from 1,4-BD products marketed as supplements or 'legal GHB alternatives.'",
      "status": "banned",
