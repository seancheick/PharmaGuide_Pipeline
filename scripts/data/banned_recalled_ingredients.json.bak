    {
      "id": "PEPTIDE_MELANOTAN_II",
      "standard_name": "Melanotan II",
      "aliases": [
        "melanotan 2",
        "MT-II",
        "MT2",
        "barbie drug",
        "tanning peptide",
        "tanning injection",
        "afamelanotide precursor",
        "melanotan ii",
        "melanotan-II"
      ],
      "reason": "Melanotan II is a synthetic analog of alpha-MSH (melanocyte-stimulating hormone) that stimulates melanogenesis, erection, and appetite suppression. It is not FDA-approved, not a dietary ingredient, and has no NDI notification. FDA has issued import alerts and warning letters. Serious safety concerns include: melanoma risk (promoting pre-existing melanocytic lesions), nausea and vomiting, spontaneous penile erections, and the near-universal practice of injection by users — creating sterility and contamination risks that do not apply to oral supplements.",
      "status": "banned",
