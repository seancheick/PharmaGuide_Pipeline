    {
      "id": "BANNED_TIANEPTINE",
      "standard_name": "Tianeptine",
      "aliases": [
        "stablon",
        "coaxil",
        "gas station heroin",
        "zaza",
        "neptune's fix",
        "tianeptine sodium",
        "tianeptine sulfate",
        "tianaa",
        "za za red",
        "tianeptine"
      ],
      "reason": "Tianeptine (brand name Stablon) is an atypical antidepressant that acts as a full agonist at mu-opioid receptors at the doses found in US supplement products. FDA has not approved it and it does not meet the definition of a dietary ingredient. Multiple states have banned it outright. At doses used in supplements (well above the therapeutic range of 12.5mg/day used in Europe), it causes opioid-like euphoria, dependence, severe withdrawal, and has been associated with overdose deaths. FDA has issued consumer warnings calling it 'gas station heroin.'",
      "status": "banned",
      "class_tags": [
        "permanently_banned",
        "nootropic"
      ],
