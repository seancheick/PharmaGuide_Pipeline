    {
      "id": "HIGH_RISK_PENNYROYAL",
      "standard_name": "Pennyroyal Oil",
      "aliases": [
        "mentha pulegium",
        "pulegium oil",
        "pennyroyal extract",
        "european pennyroyal",
        "pennyroyal",
        "pennyroyal oil"
      ],
      "reason": "Pennyroyal (Mentha pulegium) essential oil and high-dose leaf extract contain pulegone, a monoterpene ketone that is metabolized by CYP2E1 to the reactive hepatotoxin menthofuran. Even a few milliliters of the essential oil can cause fulminant liver failure and death. The oil was historically used as an abortifacient — making it particularly dangerous during pregnancy. Multiple fatal cases have been documented in the literature. FDA's Poisonous Plant Database lists it as toxic. Pennyroyal oil and high-concentration extracts should never be ingested. Topical use at very low concentrations is less concerning.",
      "status": "high_risk",
      "class_tags": [
        "high_risk_ingredients",
        "botanical"
      ],
