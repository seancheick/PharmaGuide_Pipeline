    {
      "id": "SPIKE_PHENOLPHTHALEIN",
      "standard_name": "Phenolphthalein",
      "aliases": [
        "laxative compound",
        "phenolphthalein"
      ],
      "reason": "Phenolphthalein was used as a laxative active ingredient in OTC products until the 1990s, when FDA removed it from the OTC laxative monograph after animal studies showed it was carcinogenic (rodent studies: ovarian and uterine cancer). It is classified as a possible human carcinogen. When found undeclared in weight-loss supplements, users receive an unapproved carcinogenic drug compound without disclosure. FDA has found phenolphthalein as an adulterant in weight-loss and body-shaping supplement products.",
      "status": "banned",
      "class_tags": [
        "illegal_spiking_agents",
        "drug_weight_loss"
      ],
      "match_rules": {
        "exclusions": [],
        "case_sensitive": false,
        "priority": 1,
