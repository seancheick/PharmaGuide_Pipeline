    {
      "id": "STIM_ALPHA_PHP",
      "standard_name": "α-PHP",
      "aliases": [
        "alpha-pyrrolidinohexanophenone",
        "PV-7",
        "alpha-pyrrolidinohexiophenone",
        "designer cathinone",
        "α-pyrrolidinohexanophenone",
        "α-php"
      ],
      "reason": "α-PHP (alpha-pyrrolidinohexanophenone) is a Schedule I synthetic cathinone ('bath salt') with potent stimulant effects comparable to methamphetamine. It is a DEA emergency Schedule I substance. It has absolutely no legitimate dietary supplement use — any product containing α-PHP is either mislabeled or fraudulently marketed. Known effects include severe tachycardia, hyperthermia, paranoia, psychosis, and cardiovascular collapse. Multiple overdose deaths have been attributed to synthetic cathinones in this class.",
      "status": "banned",
      "class_tags": [
        "designer_stimulants",
        "stimulant_designer"
      ],
