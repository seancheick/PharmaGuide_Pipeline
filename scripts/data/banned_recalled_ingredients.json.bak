    {
      "id": "PHARMA_DAPOXETINE",
      "standard_name": "Dapoxetine",
      "aliases": [
        "priligy",
        "westoxetin",
        "SSRIs in supplements",
        "dapoxetine hydrochloride",
        "dapoxetine"
      ],
      "reason": "Dapoxetine is a short-acting SSRI developed specifically for premature ejaculation. It is approved as a prescription drug in over 50 countries but has never been FDA-approved — the agency rejected it twice over cardiovascular safety signals (syncope, orthostatic hypotension). When found undeclared in supplements, it exposes users to drug interactions (serotonin syndrome risk with other SSRIs or MAOIs), blood pressure effects, and use without medical supervision. Its presence in any supplement constitutes adulteration with an unapproved new drug.",
