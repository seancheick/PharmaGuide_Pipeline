    {
      "id": "SARM_CARDARINE",
      "standard_name": "Cardarine",
      "aliases": [
        "GW501516",
        "GW-501516",
        "endurobol",
        "cardarine",
        "GW 501516"
      ],
      "reason": "Cardarine (GW501516) is a synthetic PPAR-delta agonist developed by GlaxoSmithKline. Clinical trials were halted in 2007 after it caused rapid multi-tissue carcinogenesis in animal studies at doses resembling those used in supplements. It is not a dietary ingredient, has never been approved by any regulatory agency, and has no NDI notification. FDA has issued warnings that products containing GW501516 are illegal and potentially unsafe. WADA prohibits it. Any supplement label listing Cardarine or GW-501516 should be treated as a safety alert.",
      "status": "banned",
      "class_tags": [
        "sarms_prohibited",
        "sarm"
      ],
