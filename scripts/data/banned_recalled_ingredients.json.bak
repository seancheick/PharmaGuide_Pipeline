    {
      "id": "HIGH_RISK_GERMANDER",
      "standard_name": "Germander",
      "aliases": [
        "teucrium chamaedrys",
        "wall germander",
        "wild germander",
        "germander extract",
        "germander"
      ],
      "reason": "Germander (Teucrium chamaedrys) was used in European weight-loss supplements until the 1990s, when over 30 cases of hepatitis and several deaths from liver failure were reported in France. France and Germany banned it. The mechanism involves toxic diterpene epoxide metabolites (from teucrin A) that are formed by CYP3A4 and cause autoimmune-mediated hepatotoxicity. The regulatory pattern — spontaneous liver injury clustering around a specific supplement — led to EFSA's classification as a substance with potential hepatotoxic effects. Internal use should be avoided.",
      "status": "high_risk",
      "class_tags": [
        "high_risk_ingredients",
        "botanical"
      ],
      "match_rules": {
        "exclusions": [],
        "case_sensitive": false,
