    {
      "id": "PEPTIDE_TB500",
      "standard_name": "TB-500 (Thymosin Beta-4)",
      "aliases": [
        "thymosin β4",
        "thymosin beta 4",
        "tb-500",
        "tb 500",
        "tb500",
        "repair peptide",
        "thymosin beta-4",
        "tb-500 (thymosin beta-4)"
      ],
      "reason": "TB-500 is a synthetic peptide analog of Thymosin Beta-4 — a naturally occurring protein involved in actin polymerization and wound repair. While marketed for recovery and healing, it has no FDA approval for any use and has not been accepted as a dietary ingredient. No NDI notification is on file. WADA prohibits it as a peptide hormone. FDA has issued warning letters and import alerts targeting TB-500 and other unapproved synthetic peptide products. Human safety and efficacy data is absent outside of anecdotal reports.",
      "status": "banned",
      "class_tags": [
        "novel_peptides",
