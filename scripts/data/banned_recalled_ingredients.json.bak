    {
      "id": "BANNED_SIBUTRAMINE",
      "standard_name": "Sibutramine",
      "aliases": [
        "meridia",
        "reductil",
        "sibutral",
        "sibutramine hydrochloride",
        "sibutramine HCl",
        "sibutramine"
      ],
      "reason": "Sibutramine (Meridia) was an FDA-approved prescription weight-loss drug (serotonin-norepinephrine reuptake inhibitor) that FDA withdrew from the US market in October 2010 after a large post-market trial (SCOUT study) found a 16% increased risk of non-fatal heart attack and non-fatal stroke in high-cardiovascular-risk patients. Despite withdrawal, sibutramine continues to be found as an undeclared adulterant in weight-loss supplements — one of the most persistent adulterants FDA's Tainted Products database tracks. Its presence in any supplement makes that product adulterated with a withdrawn prescription drug.",
      "status": "banned",
