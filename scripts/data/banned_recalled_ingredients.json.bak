    {
      "id": "SPIKE_SILDENAFIL",
      "standard_name": "Sildenafil",
      "aliases": [
        "viagra",
        "revatio",
        "PDE5 inhibitor",
        "sildenafil citrate",
        "sildenafil",
        "Sildenafil Citrate"
      ],
      "reason": "Sildenafil (Viagra) is a prescription PDE5 inhibitor for erectile dysfunction. When added undeclared to supplements — typically sexual enhancement products — users can experience life-threatening hypotension if combined with nitrates (used for angina/heart disease), as well as vision loss and cardiovascular events. FDA operates a dedicated Sexual Enhancement Fraud program due to the prevalence of this adulterant. Products with undeclared sildenafil are adulterated with a prescription drug, regardless of marketing claims.",
