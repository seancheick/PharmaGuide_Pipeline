    {
      "id": "HM_CADMIUM",
      "standard_name": "Cadmium",
      "aliases": [
        "cadmium contamination",
        "cadmium compounds",
        "cadmium",
        "cd"
      ],
      "reason": "Cadmium is a heavy metal contaminant that accumulates in the kidneys over decades, causing progressive renal tubular damage and ultimately kidney failure (itai-itai disease at high environmental exposures). It also causes bone demineralization by interfering with vitamin D metabolism. IARC Group 1 carcinogen (lung cancer, endometrial cancer evidence). California Prop 65 MADL: 4.1 mcg/day. WHO provisional tolerable monthly intake: 25 mcg/kg bw. Common in plant-based supplements grown in cadmium-rich soils (cocoa, leafy greens, grains). FDA has no specific cadmium limit for dietary supplements but monitors under general adulteration provisions.",
      "status": "high_risk",
      "class_tags": [
        "heavy_metal_limits",
        "heavy_metal"
      ],
