    {
      "id": "SARM_ANDARINE",
      "standard_name": "Andarine",
      "aliases": [
        "S4",
        "GTx-007",
        "andarine",
        "S-4"
      ],
      "reason": "Andarine (S4, GTX-007) is a synthetic selective androgen receptor modulator (SARM) developed as an investigational drug for muscle wasting and osteoporosis. It was never approved for any medical use and is not a lawful dietary supplement ingredient. At doses used in supplements, it has caused reversible visual disturbances — yellow-tinted vision and difficulty adapting to light and dark — as well as androgenic suppression of testosterone. WADA prohibits it. Supplements containing S4 are adulterated.",
