    {
      "id": "RISK_KAVA",
      "standard_name": "Kava",
      "aliases": [
        "piper methysticum",
        "kava kava",
        "kava extract",
        "kavain",
        "kava",
        "awa"
      ],
      "reason": "Kava (Piper methysticum) root extract has been associated with over 100 documented cases of severe liver injury globally, including hepatitis, cirrhosis, and liver failure requiring transplantation. Germany, Canada, Switzerland, France, and the UK have banned or restricted kava supplements. The mechanism may involve kavalactone metabolites (pipermethystine) or CYP2D6/CYP3A4 inhibition causing drug interactions. FDA issued a consumer advisory in 2002 warning of the potential for rare but severe liver injury. At-risk populations include people with liver disease or those taking hepatotoxic medications.",
      "status": "high_risk",
      "class_tags": [
        "high_risk_ingredients",
        "nootropic_anxiolytic"
      ],
