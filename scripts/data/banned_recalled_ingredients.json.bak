{
  "_metadata": {
    "description": "Banned and recalled ingredients database for regulatory compliance and safety (v3.0)",
    "purpose": "safety_disqualification_and_regulatory_compliance",
    "schema_version": "5.2.0",
    "last_updated": "2026-04-17",
    "total_entries": 143,
    "data_source_metadata": {
      "sources": [
        "FDA",
        "WADA",
        "DEA",
        "internal_curation"
      ],
      "update_frequency": "monthly"
    },
    "audit_runbook": {
      "summary": "Run the strict audit before production use. Only keep cui null when the entry is multi-concept/class-level or there is still no confirmed exact UMLS concept after alias review.",
      "quick_audit_command": ".venv/bin/python scripts/api_audit/audit_banned_recalled_accuracy.py --fda-report-in scripts/fda_sync_report_latest.json",
      "release_command": ".venv/bin/python scripts/api_audit/audit_banned_recalled_accuracy.py --release --fda-report-in scripts/fda_sync_report_latest.json",
      "release_strict_command": ".venv/bin/python scripts/api_audit/audit_banned_recalled_accuracy.py --release-strict-cui --fda-report-in scripts/fda_sync_report_latest.json",
      "run_fda_sync_then_audit_command": ".venv/bin/python scripts/api_audit/audit_banned_recalled_accuracy.py --run-fda-sync --days 30 --fda-report-out scripts/fda_sync_report_latest.json",
      "verify_cui_dry_run_command": ".venv/bin/python scripts/api_audit/verify_cui.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients --id-field id --cui-field cui",
      "verify_cui_manual_command": ".venv/bin/python scripts/api_audit/verify_cui.py --search \"sildenafil\"",
      "verify_single_cui_command": ".venv/bin/python scripts/api_audit/verify_cui.py --cui C0529793",
      "safe_apply_command": ".venv/bin/python scripts/api_audit/verify_cui.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients --id-field id --cui-field cui --apply",
      "mismatch_apply_command": ".venv/bin/python scripts/api_audit/verify_cui.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients --id-field id --cui-field cui --apply --apply-mismatches",
      "verify_pubmed_command": ".venv/bin/python scripts/api_audit/verify_pubmed_references.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients --output /tmp/banned_recalled_pubmed_verify.json",
      "verify_unii_dry_run_command": ".venv/bin/python scripts/api_audit/verify_unii.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients",
      "verify_unii_safe_apply_command": ".venv/bin/python scripts/api_audit/verify_unii.py --file scripts/data/banned_recalled_ingredients.json --list-key ingredients --apply"
    },
    "cui_audit_policy": {
      "operator_note": "Before accepting a null CUI, confirm the standard name and aliases are already sufficient for exact matching. If a missing exact synonym is the blocker, add that alias and rerun verify_cui.py before keeping cui null.",
      "approved_null_statuses": [
        "no_confirmed_umls_match",
        "no_single_umls_concept"
      ],
      "approved_null_status_meanings": {
        "no_confirmed_umls_match": "Use when the entry is a specific ingredient or analogue but no confirmed exact UMLS concept exists even after alias review.",
        "no_single_umls_concept": "Use when the entry is a class, policy, umbrella, product recall, or multi-substance record where one UMLS concept would be misleading."
      }
    },
    "unii_audit_policy": {
      "operator_note": "Use GSRS/UNII for substance identity only. Product recalls and class/watchlist entries should stay non-UNII when one GSRS substance would misrepresent the record.",
      "approved_governed_null_meanings": {
        "product": "Branded recalled products are not single GSRS substances and should stay governed_null unless a human intentionally introduces a product-level identity strategy.",
        "class": "Class/watchlist records span multiple substances and should not be collapsed to one GSRS ingredient.",
        "no_single_umls_concept": "If the CUI layer already documents the record as multi-concept, GSRS should follow the same governed-null policy unless an exact reviewed substance exception exists."
      }
    },
