    {
      "id": "BANNED_BMPEA",
      "standard_name": "BMPEA",
      "aliases": [
        "β-methylphenylethylamine",
        "R-beta-methylphenylethylamine",
        "beta-methylphenylethylamine",
        "BMPEA",
        "beta-methylphenyl-ethylamine"
      ],
      "reason": "BMPEA (β-methylphenylethylamine, 4-amino-2-methylpentane) is a synthetic amphetamine-like compound found by FDA researchers as an undeclared ingredient in supplements labeled as containing 'Acacia rigidula extract' — a species in which BMPEA does not naturally occur. BMPEA has stimulant activity; it raises blood pressure and heart rate and has structural similarity to amphetamines. FDA confirmed its presence in 9 of 21 tested Acacia rigidula supplements (2015). It is not a lawful dietary ingredient. Products containing it are adulterated.",
      "status": "banned",
      "class_tags": [
        "permanently_banned",
        "stimulant"
      ],
