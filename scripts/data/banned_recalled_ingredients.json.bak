    {
      "id": "SPIKE_TIANEPTINE_ANALOGUES",
      "standard_name": "Policy Watchlist: Tianeptine Analogues",
      "aliases": [
        "tianeptine analogues",
        "modified tianeptine",
        "ethyl-tianeptine",
        "methyl-tianeptine",
        "fluorinated tianeptine"
      ],
      "reason": "Tianeptine analogue compounds are designer drug variants engineered to mimic tianeptine — an atypical antidepressant with mu-opioid receptor agonist activity. FDA has not approved tianeptine for any use (see BANNED_TIANEPTINE). Designer analogs are created to evade listing and scheduling while retaining the opioid-like and addiction properties of the parent compound. When found in supplements, users face opioid-like dependence, withdrawal, and overdose risk without any labeling indicating the opioid mechanism.",
      "status": "banned",
      "class_tags": [
