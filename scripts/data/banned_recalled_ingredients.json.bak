    {
      "id": "SPIKE_FLUOXETINE",
      "standard_name": "Fluoxetine",
      "aliases": [
        "prozac",
        "SSRI antidepressant",
        "fluoxetine hydrochloride",
        "fluoxetine"
      ],
      "reason": "Fluoxetine (Prozac) is a prescription SSRI antidepressant requiring clinical diagnosis, dosing oversight, and monitoring. When found undeclared in supplements, users receive an SSRI without medical supervision, putting them at risk for serotonin syndrome (especially if already on antidepressants or MAOIs), sexual dysfunction, withdrawal effects upon stopping the product, and dangerous interactions with blood thinners (warfarin potentiation). FDA considers any supplement containing fluoxetine to be adulterated with a prescription drug.",
