    {
      "id": "HM_ARSENIC",
      "standard_name": "Arsenic (Inorganic)",
      "aliases": [
        "arsenic contamination",
        "arsenite",
        "arsenate",
        "arsenic (inorganic)",
        "as",
        "inorganic arsenic"
      ],
      "reason": "Inorganic arsenic is an IARC Group 1 human carcinogen linked to skin, lung, bladder, and kidney cancers at chronic dietary exposure levels. It also causes peripheral neuropathy, cardiovascular disease, and diabetes. Organic arsenic (found in seafood) is less toxic. EPA MCL for arsenic in drinking water: 10 mcg/L. California Prop 65 NSRL: 10 mcg/day. FDA action level for rice-based infant cereal: 100 ppb inorganic arsenic. In supplements, arsenic contamination is most common in rice protein, kelp, spirulina, certain Ayurvedic preparations, and marine-sourced ingredients. Testing for organic vs. inorganic speciation is essential for accurate risk assessment.",
      "status": "high_risk",
      "class_tags": [
        "heavy_metal_limits",
        "heavy_metal"
      ],
