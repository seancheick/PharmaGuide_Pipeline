    {
      "id": "HM_MERCURY",
      "standard_name": "Mercury",
      "aliases": [
        "mercury contamination",
        "methylmercury",
        "mercury compounds",
        "mercury",
        "hg"
      ],
      "reason": "Mercury — particularly organic methylmercury — is a potent neurotoxin that crosses the blood-brain barrier and placenta. It causes irreversible neurological damage, especially in the developing brain (prenatal and early childhood exposure). EPA/FDA reference dose for methylmercury: 0.1 mcg/kg bw/day. IARC: Group 2B (inorganic mercury), Group 1 for methylmercury from occupational data. In supplements, mercury contamination is most common in fish oils, certain botanical powders, and traditional medicinal preparations. Pregnant women and young children are at highest risk.",
      "status": "high_risk",
      "class_tags": [
        "heavy_metal_limits",
        "heavy_metal"
      ],
