    {
      "id": "BANNED_IBOTENIC_ACID",
      "standard_name": "Ibotenic Acid",
      "aliases": [
        "ibotenic acid",
        "ibotenate",
        "DL-ibotenic acid",
        "alpha-amino-3-hydroxy-5-isoxazoleacetic acid"
      ],
      "reason": "Ibotenic acid is a neurotoxic amino acid found in Amanita muscaria alongside muscimol. It is an NMDA receptor agonist and glutamate analog that causes excitotoxicity. Decarboxylates to muscimol during drying/processing. The combination of ibotenic acid (excitotoxin) and muscimol (GABAergic sedative) creates an unpredictable and dangerous pharmacological profile. Ibotenic acid is used in neuroscience research to create brain lesions — its neurotoxicity is well-established.",
      "status": "banned",
