    {
      "id": "ADULTERANT_MELOXICAM",
      "standard_name": "Meloxicam",
      "aliases": [
        "meloxicam",
        "mobic",
        "meloxicam sodium",
        "meloxicam tablets"
      ],
      "reason": "Meloxicam (Mobic) is a prescription NSAID selective for COX-2, used for arthritis pain. When found undeclared in dietary supplements, users are unknowingly exposed to NSAID risks without medical oversight: GI bleeding, renal impairment, fluid retention, and elevated cardiovascular risk. Users on anticoagulants, aspirin, or ACE inhibitors face compounded risks. FDA has identified meloxicam as a pharmaceutical adulterant in joint and pain-related supplement products. Any supplement containing it is adulterated with a prescription drug.",
      "status": "banned",
      "class_tags": [
        "pharmaceutical_adulterants",
        "drug_nsaid"
      ],
      "match_rules": {
