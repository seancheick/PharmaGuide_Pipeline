{
  "_metadata": {
    "description": "Allowlist/denylist for banned ingredient matching overrides",
    "purpose": "match_override",
    "schema_version": "4.0.0",
    "last_updated": "2026-02-17",
    "version": "1.0.0",
    "total_entries": 5
  },
  "allowlist": [
    {
      "id": "ALLOW_IGF1",
      "canonical_id": "BANNED_IGF1",
      "canonical_term": "IGF-1 (Insulin-like Growth Factor 1)",
      "match_policy": "token_bounded_hyphen_space",
      "variants": [
        "igf-1",
        "igf 1"
      ],
      "notes": "Allow IGF-1 variants with hyphen/space differences.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "ALLOW_IGF1_COMPACT",
      "canonical_id": "BANNED_IGF1",
      "canonical_term": "IGF-1 (Insulin-like Growth Factor 1)",
      "match_policy": "token_bounded",
      "variants": [
        "igf1"
      ],
      "notes": "Allow compact IGF1 token.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "ALLOW_PHO",
      "canonical_id": "BANNED_PHO",
      "canonical_term": "Partially Hydrogenated Oils (PHOs)",
      "match_policy": "token_bounded",
      "variants": [
        "pho",
        "phos"
      ],
      "notes": "Allow PHO abbreviations.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "ALLOW_PARTIALLY_HYDROGENATED_OIL",
      "canonical_id": "BANNED_PHO",
      "canonical_term": "Partially Hydrogenated Oils (PHOs)",
      "match_policy": "token_bounded_hyphen_space",
      "variants": [
        "partially hydrogenated oil",
        "partially hydrogenated oils",
        "partially hydrogenated vegetable oil",
        "partially hydrogenated soybean oil",
        "partially hydrogenated cottonseed oil",
        "partially hydrogenated palm oil",
        "partially hydrogenated canola oil"
      ],
      "notes": "Allow common PHO phrases with hyphen/space variation.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "ALLOW_IGF1_LR3",
      "canonical_id": "BANNED_IGF1_LR3",
      "canonical_term": "IGF-1 LR3 (Long R3 Insulin-like Growth Factor 1)",
      "match_policy": "token_bounded_hyphen_space",
      "variants": [
        "igf-1 lr3",
        "igf 1 lr3",
        "igf1 lr3",
        "igf-1lr3",
        "igf1lr3",
        "long r3 igf-1",
        "long r3 igf 1",
        "long r3 igf1",
        "lr3 igf-1",
        "lr3 igf 1",
        "lr3 igf1",
        "lr3-igf-1",
        "lr3-igf1"
      ],
      "notes": "Allow all LR3 IGF-1 variants to match BANNED_IGF1_LR3 (NOT BANNED_IGF1).",
      "created_at": "2026-01-08",
      "updated_at": "2026-01-08"
    }
  ],
  "denylist": [
    {
      "id": "DENY_IGF_BINDING_PROTEIN",
      "canonical_id": "BANNED_IGF1",
      "canonical_term": "IGF-1 (Insulin-like Growth Factor 1)",
      "pattern": "(?<![a-z0-9])igf[-\\s]+binding[-\\s]+protein(?![a-z0-9])",
      "match_policy": "token_bounded_regex",
      "notes": "Do not match IGF binding proteins as IGF-1.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "DENY_IGFBP",
      "canonical_id": "BANNED_IGF1",
      "canonical_term": "IGF-1 (Insulin-like Growth Factor 1)",
      "pattern": "(?<![a-z0-9])igfbp\\d*(?![a-z0-9])",
      "match_policy": "token_bounded_regex",
      "notes": "Do not match IGFBP family abbreviations as IGF-1.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "DENY_IGF1_LR3",
      "canonical_id": "BANNED_IGF1",
      "canonical_term": "IGF-1 (Insulin-like Growth Factor 1)",
      "pattern": "(?<![a-z0-9])((igf[-\\s]*1[-\\s]*(lr3|long[-\\s]*r3))|(long[-\\s]*r3[-\\s]*igf[-\\s]*1))(?![a-z0-9])",
      "match_policy": "token_bounded_regex",
      "notes": "Prevent IGF-1 from matching LR3 analogs (handled separately).",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    },
    {
      "id": "DENY_PHO_FREE",
      "canonical_id": "BANNED_PHO",
      "canonical_term": "Partially Hydrogenated Oils (PHOs)",
      "pattern": "(?<![a-z0-9])pho(?:s)?[-\\s]*free(?![a-z0-9])",
      "match_policy": "token_bounded_regex",
      "notes": "Do not match PHO-free claims as ingredients.",
      "created_at": "2026-01-09",
      "updated_at": "2026-01-09"
    }
  ]
}
