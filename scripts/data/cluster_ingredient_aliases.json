  "_metadata": {
    "description": "Canonical-form ingredient aliases for synergy cluster matching. Each canonical form maps to the variant strings that supplement labels use in the wild. Used by enrich_supplements_v3.py::_collect_synergy_data to recover products where DSLD parser writes 'coenzyme q10' but the cluster ingredient is 'coq10'.",
    "purpose": "cluster_ingredient_aliasing",
    "schema_version": "1.0.0",
    "last_updated": "2026-04-24",
    "total_entries": 25,
    "schema_notes": {
      "key": "Canonical ingredient form as it appears in synergy_cluster.json's `ingredients` lists.",
      "value": "List of alternative spellings, abbreviations, source compounds, and chemical synonyms that should match the canonical form.",
      "ambiguity_rule": "Each alias string may belong to AT MOST ONE canonical key. Aliases that could resolve to multiple canonical ingredients (e.g. 'ALA' = alpha-lipoic-acid OR alpha-linolenic-acid) must NOT be added; use the unambiguous full name instead.",
      "scope": "Cluster matching only. Does NOT affect ingredient_quality_map scoring or IQM canonical IDs — those have their own alias system in enhanced_normalizer.py."
    }
  },
