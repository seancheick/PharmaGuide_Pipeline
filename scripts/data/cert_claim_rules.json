{
  "_metadata": {
    "description": "Versioned rules for certification/claim detection with evidence-based scoring eligibility",
    "purpose": "claims_scoring",
    "schema_version": "5.0.0",
    "last_updated": "2026-02-25",
    "scoring_rule": "Only award points when evidence_strength >= 'medium' AND score_eligible=true AND feature gate enabled",
    "design_principles": [
      "Separation of concerns: Enrichment extracts claims, Scoring computes points",
      "Evidence objects: Every claim has full audit trail (rule_id, matched_text, source_field)",
      "Negative pattern validation: Reject false positives before scoring",
      "Scope enforcement: Product-level claims only from approved fields",
      "Feature gating: All scoring gates default OFF until validated"
    ],
    "confidence_tiers": {
      "strong": "Always eligible for scoring - explicit certifications with verification",
      "medium": "Eligible with caution - clear claims without negation",
      "weak": "NEVER eligible for scoring - vague marketing, UI display only"
    },
    "pipeline_integration": {
      "enrichment": "enrich_supplements_v3.py loads this DB, extracts claims with evidence objects",
      "scoring": "score_supplements.py only scores claims where score_eligible=true AND gate enabled",
      "contract": "enrichment_contract_validator.py enforces rules"
    },
    "sources": [
      "https://www.usp.org/verification-services",
      "https://www.nsfsport.com/",
      "https://www.consumerlab.com/",
      "https://www.nsf.org/consumer-resources/articles/supplements-and-gmp",
      "https://www.fda.gov/food/dietary-supplements-guidance-documents-regulatory-information"
    ],
    "statistics": {
      "third_party_programs": 10,
      "gmp_certifications": 7,
      "organic_certifications": 2,
      "allergen_free_claims": 16,
      "batch_traceability": 4,
      "quality_markers": 6,
      "total_rules": 45
    },
    "total_entries": 45
  },
  "config": {
    "source_field_groups": {
      "_description": "Centralized field groups for scope validation. Claims reference these by name.",
      "product_level_fields": [
        "statements",
        "qualityFeatures",
        "certifications",
        "claims",
        "labelText.parsed.certifications",
        "labelText.parsed.qualityFeatures",
        "labelText.raw"
      ],
      "ingredient_fields": [
        "ingredients",
        "activeIngredients",
        "inactiveIngredients",
        "supplementFacts",
        "otherIngredients",
        "ingredientRows"
      ],
      "any_field": [
        "*"
      ]
    },
    "dedupe_rules": {
      "_description": "Programs with same dedupe_key are counted once in scoring. Prevents double-counting related certifications.",
      "program_families": {
        "nsf": {
          "note": "NSF Sport, NSF Certified, NSF GMP are DIFFERENT programs - don't merge",
          "members": [
            "nsf_sport",
            "nsf_certified",
            "nsf_gmp",
            "nsf_contents_certified"
          ]
        },
        "usp": {
          "note": "USP Verified is the only scoreable USP claim. USP Grade/standards are NOT certifications.",
          "members": [
            "usp_verified"
          ]
        },
        "informed": {
          "note": "Informed Sport and Informed Choice are separate programs",
          "members": [
            "informed_sport",
            "informed_choice"
          ]
        }
      }
    }
  },
  "rules": {
    "third_party_programs": {
      "_metadata": {
        "description": "Third-party testing/certification programs - highest value certifications",
        "max_programs_scored": 2,
        "points_per_program": 5,
        "max_total_points": 10
      },
      "usp_verified": {
        "id": "CERT_USP_VERIFIED",
        "display_name": "USP Verified",
        "dedupe_key": "third_party_program:usp_verified",
        "claim_type": "third_party_certification",
        "positive_patterns": [
          "\\bUSP[\\s-]+Verified\\b",
          "\\bUSP[\\s-]+Verification[\\s-]+Program\\b",
          "\\bUSP[\\s-]+Dietary[\\s-]+Supplement[\\s-]+Verified\\b",
          "\\bUSP[\\s-]+Verified[\\s-]+Dietary[\\s-]+Supplement\\b"
        ],
        "negative_patterns": [
          "\\bUSP\\s+standards?\\b",
          "\\bmeets?\\s+USP\\s+specifications?\\b",
          "\\bUSP\\s+grade\\b",
          "\\bUSP\\s+<\\d+>\\b",
          "\\bUSP\\s+quality\\b",
          "\\bnot\\s+USP\\s+verified\\b"
        ],
        "required_tokens": [
          "verified",
          "verification"
        ],
        "required_tokens_note": "At least one of these tokens must be present for scoring eligibility",
        "evidence_strength": "strong",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 5,
        "verification_url": "https://www.quality-supplements.org/verified-products",
        "notes": "USP Verified is a rigorous third-party certification. 'USP standards' or 'USP grade' are NOT certifications - they're quality claims about ingredient purity."
      },
      "nsf_sport": {
        "id": "CERT_NSF_SPORT",
        "display_name": "NSF Certified for Sport",
        "dedupe_key": "third_party_program:nsf_sport",
        "claim_type": "third_party_certification",
        "positive_patterns": [
          "\\bNSF\\s+Certified(?:\\s+for)?\\s+Sport\\b",
          "\\bNSF\\s+Sport\\b",
          "\\bCertified\\s+for\\s+Sport\\b"
        ],
        "negative_patterns": [
          "\\bnot\\s+NSF\\s+certified\\b",
          "\\bpending\\s+NSF\\b"
        ],
        "evidence_strength": "strong",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 5,
        "verification_url": "https://www.nsfsport.com/certified-products/",
        "notes": "Gold standard for athletes - tests for banned substances"
      },
      "nsf_contents_certified": {
        "id": "CERT_NSF_CONTENTS",
        "display_name": "NSF Contents Certified",
        "dedupe_key": "third_party_program:nsf_contents_certified",
        "claim_type": "third_party_certification",
        "positive_patterns": [
          "\\bNSF\\s+Contents\\s+Certified\\b",
          "\\bNSF/ANSI\\s*173\\b",
          "\\bNSF\\s+173\\b"
        ],
        "negative_patterns": [],
        "evidence_strength": "strong",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 5,
        "notes": "Certifies label accuracy - what's on the label is in the bottle"
      },
