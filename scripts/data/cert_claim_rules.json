        "negative_patterns": [],
        "evidence_strength": "weak",
        "scope_rule": "any",
        "approved_field_group": "any_field",
        "points_if_eligible": 0,
        "notes": "Ingredient-level organic is for UI display only - not scoreable as product certification"
