        "points_if_eligible": 4
      },
      "cgmp_certified": {
        "id": "CERT_CGMP",
        "display_name": "cGMP Certified",
        "dedupe_key": "gmp:cgmp",
        "claim_type": "gmp_certification",
        "positive_patterns": [
          "\\bcGMP[\\s-]*(Certified|Compliant)\\b",
          "\\b21\\s*CFR\\s*Part\\s*(210|211)\\s*(compliant|certified)\\b"
        ],
        "negative_patterns": [
          "\\bfollows?\\s+cGMP\\b",
          "\\bcGMP\\s+practices\\b"
        ],
        "evidence_strength": "medium",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 4,
        "notes": "cGMP is FDA's Current Good Manufacturing Practice - 'certified' implies third-party audit"
      },
      "gmp_explicit": {
        "id": "CERT_GMP_EXPLICIT",
        "display_name": "GMP Certified Facility",
        "dedupe_key": "gmp:explicit",
        "claim_type": "gmp_certification",
        "positive_patterns": [
          "\\bGMP[\\s-]+(certified|registered)[\\s-]+(facility|manufacturing)\\b",
          "\\b(certified|registered)[\\s-]+GMP[\\s-]+(facility|manufacturing)\\b"
        ],
        "negative_patterns": [
          "\\bGMP\\s+practices\\b",
          "\\bfollows?\\s+GMP\\b",
          "\\bGMP\\s+guidelines\\b"
        ],
        "evidence_strength": "medium",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 4,
        "notes": "Explicit GMP certification claim - stronger than vague GMP"
      },
      "gmp_generic": {
        "id": "CERT_GMP_GENERIC",
        "display_name": "GMP (Generic Claim)",
        "dedupe_key": "gmp:generic",
        "claim_type": "gmp_certification",
        "positive_patterns": [
          "\\bGMP\\b(?!\\s*(certified|registered|compliant))",
          "\\bGood\\s+Manufacturing\\s+Practices?\\b"
        ],
        "negative_patterns": [
          "\\bNSF\\s*GMP\\b",
          "\\bNPA\\s*GMP\\b",
          "\\bUL\\s*GMP\\b",
          "\\bcGMP\\b"
        ],
        "evidence_strength": "weak",
        "scope_rule": "any",
        "approved_field_group": "any_field",
        "points_if_eligible": 0,
        "notes": "Generic GMP mention without certification body - weak evidence, UI display only. All US supplements must follow GMP by law."
      },
      "fda_registered": {
        "id": "CERT_FDA_REGISTERED",
        "display_name": "FDA Registered Facility",
        "dedupe_key": "gmp:fda_registered",
        "claim_type": "gmp_certification",
        "positive_patterns": [
          "\\bFDA[\\s-]*(registered|inspected)\\s*(facility|supplement)?\\b"
        ],
        "negative_patterns": [
          "\\bFDA\\s+approved\\b"
        ],
        "evidence_strength": "weak",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 0,
        "notes": "FDA registration is required by law for all supplement facilities - not a distinguishing certification"
      }
    },
    "organic_certifications": {
      "_metadata": {
        "description": "Organic certifications - product-level only",
        "max_points": 2,
        "notes": "Scope is critical: 'Organic vitamin C' in ingredient list =/= 'USDA Organic' certified product"
      },
