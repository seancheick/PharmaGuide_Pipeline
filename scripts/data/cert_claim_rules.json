          "\\bNatural\\s+Products\\s+Association\\s+GMP\\b"
        ],
        "negative_patterns": [],
        "evidence_strength": "strong",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 4
      },
      "ul_gmp": {
        "id": "CERT_UL_GMP",
        "display_name": "UL GMP Certified",
        "dedupe_key": "gmp:ul",
        "claim_type": "gmp_certification",
        "positive_patterns": [
          "\\bUL[\\s-]*(Solutions[\\s-]*)?GMP\\b"
        ],
