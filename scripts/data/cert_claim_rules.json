          "\\bnot\\s+(USDA[\\s-]+)?organic\\b",
          "\\bnot\\s+certified[\\s-]+organic\\b"
        ],
        "required_tokens": [
          "usda",
          "certified",
          "100%",
          "100 percent"
        ],
        "required_tokens_mode": "any",
        "evidence_strength": "strong",
        "scope_rule": "product_level_only",
        "approved_field_group": "product_level_fields",
        "points_if_eligible": 2,
        "notes": "USDA Organic requires explicit certification language (USDA/Certified/100%). 'Organic [ingredient]' alone is not sufficient."
      },
