          "severity": "avoid",
          "evidence_level": "probable",
          "mechanism": "Yohimbe can counter blood pressure-lowering therapy.",
          "action": "Avoid combination with antihypertensive medications.",
          "sources": [
            "https://www.nccih.nih.gov/health/safety"
          ]
        }
      ],
      "pregnancy_lactation": {
        "pregnancy_category": "contraindicated",
        "lactation_category": "avoid",
        "evidence_level": "probable",
        "mechanism": "Safety data are limited and stimulant effects are concerning.",
        "notes": "Avoid in pregnancy and lactation.",
        "sources": [
          "https://www.nccih.nih.gov/health/safety"
        ]
      },
