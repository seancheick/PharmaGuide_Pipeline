          "severity": "contraindicated",
          "evidence_level": "probable",
          "mechanism": "Stimulant profile and hemodynamic effects present maternal-fetal risk concerns.",
          "action": "Do not use during pregnancy.",
          "sources": [
            "https://www.nccih.nih.gov/health/safety"
          ]
        }
      ],
      "drug_class_rules": [
