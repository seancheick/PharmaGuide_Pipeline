    {
      "id": "RULE_BANNED_EPHEDRA_PREGNANCY",
      "subject_ref": {
        "db": "banned_recalled_ingredients",
        "canonical_id": "BANNED_EPHEDRA"
      },
      "condition_rules": [
        {
          "condition_id": "pregnancy",
          "severity": "contraindicated",
          "evidence_level": "established",
          "mechanism": "Ephedra has serious cardiovascular and neurologic risks and is FDA-banned as a supplement ingredient.",
          "action": "Do not use in pregnancy.",
          "sources": [
            "https://www.nccih.nih.gov/health/ephedra",
            "https://www.fda.gov/food/dietary-supplements/information-select-dietary-supplement-ingredients-and-other-substances"
          ]
        }
      ],
      "drug_class_rules": [
        {
          "drug_class_id": "antihypertensives",
          "severity": "avoid",
          "evidence_level": "established",
          "mechanism": "Adrenergic stimulation can antagonize blood-pressure control therapies.",
          "action": "Avoid use with antihypertensives.",
          "sources": [
            "https://www.nccih.nih.gov/health/ephedra"
          ]
        }
      ],
      "dose_thresholds": [],
      "pregnancy_lactation": {
        "pregnancy_category": "contraindicated",
        "lactation_category": "avoid",
        "evidence_level": "established",
        "mechanism": "Serious toxicity risk profile and regulatory prohibition for supplement use.",
        "notes": "Ephedra-containing supplements should not be used.",
        "sources": [
          "https://www.nccih.nih.gov/health/ephedra"
        ]
      },
      "last_reviewed": "2026-02-28",
      "review_owner": "pharmaguide_clinical_team"
    },
