      "id": "RULE_IQM_IODINE_PREGNANCY_EXCESS",
      "subject_ref": {
        "db": "ingredient_quality_map",
        "canonical_id": "iodine"
      },
      "condition_rules": [
        {
          "condition_id": "pregnancy",
          "severity": "monitor",
          "evidence_level": "established",
          "mechanism": "Iodine is essential in pregnancy, but excessive intake can adversely affect maternal/fetal thyroid function.",
          "action": "Keep total iodine intake within guideline ranges; avoid excess supplementation.",
          "sources": [
            "https://ods.od.nih.gov/factsheets/Iodine-HealthProfessional/"
          ]
        }
      ],
      "drug_class_rules": [
        {
          "drug_class_id": "thyroid_medications",
          "severity": "monitor",
          "evidence_level": "probable",
          "mechanism": "High iodine intake can alter thyroid physiology and therapy response.",
          "action": "Coordinate iodine supplements with thyroid medication management.",
          "sources": [
            "https://ods.od.nih.gov/factsheets/Iodine-HealthProfessional/"
          ]
        }
      ],
      "dose_thresholds": [
        {
          "scope": "condition",
          "target_id": "pregnancy",
          "basis": "per_day",
          "comparator": ">",
          "value": 1100,
          "unit": "mcg",
          "severity_if_met": "avoid",
          "severity_if_not_met": "monitor"
        }
      ],
      "pregnancy_lactation": {
        "pregnancy_category": "monitor",
        "lactation_category": "monitor",
        "evidence_level": "established",
        "mechanism": "Both deficiency and excess can be harmful; UL and recommended intake should guide use.",
        "notes": "Threshold escalates only on excess; baseline reflects required-but-dose-sensitive nutrient status.",
        "sources": [
          "https://ods.od.nih.gov/factsheets/Iodine-HealthProfessional/"
        ]
      },
      "last_reviewed": "2026-02-28",
      "review_owner": "pharmaguide_clinical_team"
    },
