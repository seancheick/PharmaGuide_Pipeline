# Python
__pycache__/
*.pyc
*.pyo
.venv/
.env


# Pipeline output (regenerable via clean → enrich → score)
scripts/output_*/
scripts/products/
scripts/tmp_*/
scripts/final_db_output/
scripts/.cache/
tmp/

# Interaction DB build working dir — regenerable via
# ingest_suppai.py → build_interaction_db.py → release_interaction_artifact.py.
# Keep the directory itself (via .gitkeep) but never commit the generated blobs.
scripts/interaction_db_output/*
!scripts/interaction_db_output/.gitkeep

# Release artifact staging (output of scripts/release_catalog_artifact.py).
# Regenerable from scripts/final_db_output/ — never commit the SQLite blob here;
# the Flutter repo owns the committed copy via Git LFS.
scripts/dist/
dist/

# Local smoke-test artifacts (ephemeral session output)
scripts/smoke/
scripts/smoke_enriched/
scripts/smoke_scored/

# Accidentally-captured browser profile state (no actual screenshots)
docs/plans/dashboard-screenshots/

# FDA CAERS bulk download (99MB unzipped — regenerable via ingest_caers.py)
scripts/data/fda_caers/

# FDA UNII bulk cache (14.9MB — regenerable via build_unii_cache.py)
scripts/data/fda_unii_cache.json
scripts/data/fda_unii_bulk.json.zip
scripts/data/other-unii-*.json

# FDA drug label bulk downloads (600MB+ per file — regenerable from OpenFDA)
scripts/data/fda_drug_labels/

# graphify output (regenerable via /graphify)
graphify-out/
.graphify_*

# Logs (regenerated each run)
scripts/logs/

# Reports (regenerated each run) — but keep Python tool sources tracked
scripts/reports/*
!scripts/reports/*.py
!scripts/reports/__init__.py

# IDE / OS
.DS_Store
.vscode/
.idea/
.cursor/
.qodo/
.planning/
.pytest_cache/
.gstack/
.kilo/
.agents/

# Local backups / scheduled-task runtime state
*.bak
*.bak.json
scripts/data/*.json.bak
.claude/scheduled_tasks.lock
.claude/